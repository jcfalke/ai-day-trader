{
  "name": "ai-day-trader",
  "version": "1.0.0",
  "private": true,
  "description": "AI Day Trader Agent Pipeline — n8n + Alpaca + Next.js Dashboard",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/backend\" \"npm run dev --workspace=packages/frontend\"",
    "build": "npm run build --workspaces",
    "agent": "npm run start --workspace=packages/agent",
    "setup": "node scripts/setup-db.js",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}

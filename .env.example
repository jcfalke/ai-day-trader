# ============================================================
# AI Day Trader — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ---- Alpaca ----
# Get from: https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_API_SECRET=your_alpaca_secret_key_here
ALPACA_PAPER_MODE=true

# ---- LLM Provider (pick one) ----
# Option A: Anthropic Claude (recommended)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
LLM_MODEL=claude-opus-4-6

# Option B: OpenAI (comment out Anthropic lines above, uncomment below)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxx
# LLM_MODEL=gpt-4o

# Option C: Local LLM via OpenAI-compatible endpoint (Ollama, LM Studio, etc.)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=not-needed
# LLM_MODEL=llama3
# LLM_BASE_URL=http://localhost:11434/v1

# ---- News (optional — falls back to Alpaca News) ----
# NEWSAPI_KEY=your_newsapi_org_key_here

# ---- Risk Parameters ----
# Max % of equity per ticker position (0–100)
MAX_POSITION_PCT=5
# Stop all trading if day loss exceeds this % of equity
MAX_DAILY_LOSS_PCT=2
# Minimum LLM confidence to place a trade (0–1)
MIN_CONFIDENCE=0.65
# Maximum simultaneous open positions
MAX_OPEN_POSITIONS=5
# Hard cap on single order value in USD
MAX_ORDER_VALUE_USD=2000
# Candle timeframe: 1Min | 5Min | 15Min | 1Hour
TIMEFRAME=5Min
# Number of bars to fetch and analyze
LOOKBACK_BARS=50
# News items per ticker
NEWS_ITEMS_PER_TICKER=5
# Tickers to watch (comma-separated)
WATCHLIST=TSLA,NVDA,SPY
# PAPER_MODE=true means log orders only — set to false to actually submit
PAPER_MODE=true

# ---- Backend ----
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001
DB_PATH=./data/trader.db

# ---- Frontend ----
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ---- Logging ----
LOG_LEVEL=info
LOG_DIR=./logs

# ---- n8n (if using self-hosted n8n) ----
# N8N_HOST=localhost
# N8N_PORT=5678
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/ai-trader
# Used as fallback in n8n order builder node
ACCOUNT_EQUITY_FALLBACK=100000
